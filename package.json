{
  "name": "monorepo-starter",
  "version": "0.0.0",
  "private": true,
  "description": "A governance-grade, supply-chain-aware, policy-driven monorepo starter with lifecycle automation and the moro CLI.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "libs/*",
    "tools/*",
    "configs/*"
  ],
  "scripts": {
    "check": "moon run root:check",
    "format": "moon run root:format",
    "format:check": "moon run root:format-check",
    "lint": "moon run root:lint",
    "typecheck": "moon run root:typecheck",
    "test": "moon run root:test",
    "build": "moon run root:build",
    "doctor": "moon run root:doctor"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@moonrepo/cli": "^2.3.5",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@moonrepo/cli"
  ]
}
